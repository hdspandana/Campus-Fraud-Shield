# .streamlit/secrets.toml.example
# Copy this to .streamlit/secrets.toml and fill in values
# secrets.toml is in .gitignore — never commit real secrets

# ── Optional API keys ─────────────────────────────────────────────
# Not required for core functionality
# All detection works offline without any API keys

[app]
# App version shown in footer
version = "1.0.0"

# ── Optional: future extensions ───────────────────────────────────
# [openai]
# api_key = "sk-..."

# [firebase]
# project_id = "..."